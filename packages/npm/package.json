{
  "name": "@jgiox/goodvibes",
  "version": "1.3.0",
  "description": "One-command bootstrap for vibe coding projects",
  "type": "module",
  "bin": {
    "goodvibes": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "engines": {
    "node": ">=20.12.0"
  },
  "files": [
    "dist",
    "templates"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/jgiox/goodvibes"
  },
  "keywords": [
    "scaffold",
    "vibe-coding",
    "claude",
    "llm",
    "starter-kit",
    "cli"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "Apache-2.0",
  "scripts": {
    "prebuild": "node -e \"const{cpSync}=require('fs');cpSync('../../templates','./templates',{recursive:true,force:true})\"",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "commander": "^13",
    "@clack/prompts": "^1",
    "fs-extra": "^11",
    "execa": "^9"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^6",
    "@types/node": "^26",
    "vitest": "^4"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
